# OpenAI-compatible model fallback. Model-pool settings in the admin UI can
# override these values; never commit a real key.
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
MODEL_CONFIG_FILE=./model_configs.json

# Local development default. Production deployments should use MySQL and a
# dedicated database account.
DATABASE_URL=sqlite:///./narrative_agent.db
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# The bootstrap token is required to create the first administrator. Replace
# this placeholder with a long random secret on the server, then remove or
# rotate it after the first administrator exists.
ADMIN_BOOTSTRAP_TOKEN=replace_with_a_long_random_secret
ALLOW_FIRST_USER_ADMIN=false

ACCESS_TOKEN_TTL_MINUTES=60
REFRESH_TOKEN_TTL_DAYS=14
NON_MEMBER_DAILY_MESSAGE_LIMIT=20
MESSAGE_RATE_LIMIT_WINDOW_SECONDS=60
MESSAGE_RATE_LIMIT_MAX_REQUESTS=10
MAX_RAG_CANDIDATES=500
